# Mode: "mock" (default, runs offline with synthetic data) or "live"
AMALOAN_MODE=mock

# Live mode (Solana mainnet) — set a Helius key OR a custom RPC.
HELIUS_API_KEY=
SOLANA_RPC_URL=

# USDC mint on Solana mainnet (default is the canonical mint).
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Comma-separated agent owner addresses to index in live mode.
# In production these come from the Solana Agent Registry / SATI.
WATCH_OWNERS=
